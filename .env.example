POSTGRES_USER=darkatlas
POSTGRES_PASSWORD=darkatlas
POSTGRES_DB=darkatlas
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg2://darkatlas:darkatlas@db:5433/darkatlas
API_KEY=replace-with-your-generated-key
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro-latest
STALE_ASSET_DAYS_INTERVAL=30.0
STALE_JOB_INTERVAL_HOURS=24.0

# Used by the test suite — point at a dedicated test DB or leave as-is
# (rows are cleaned up after every test, so sharing the main DB is safe locally)
TEST_DATABASE_URL=postgresql+psycopg2://darkatlas:darkatlas@localhost:5433/darkatlas_test